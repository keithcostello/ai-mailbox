# AI Mailbox — Environment Variables
# Copy to .env and fill in values

# Railway auto-sets this when you add Postgres plugin
DATABASE_URL=

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MAILBOX_JWT_SECRET=

# User passwords for OAuth login
MAILBOX_KEITH_PASSWORD=
MAILBOX_AMY_PASSWORD=

# Railway auto-sets this
PORT=8000

# Optional
LOG_LEVEL=INFO
